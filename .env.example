# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Yahoo App Password setup:
#   1. Go to https://login.yahoo.com/security/app-passwords
#   2. Sign in → Generate app password → name it "Guitar Site"
#   3. Paste the generated password as SMTP_PASSWORD below

SMTP_HOST=smtp.mail.yahoo.com
SMTP_USERNAME=domaindesigners@yahoo.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_PORT=587
SMTP_FROM=domaindesigners@yahoo.com
SMTP_FROM_NAME="JCR Music Studio"
MAIL_TO=domaindesigners@yahoo.com
MAIL_TO_NAME="Domain Designers"
MAIL_DEBUG=0
# URL of the deployed site (no trailing slash) — used in slot-action email buttons
SITE_URL=https://yourdomain.com
# Random secret for HMAC-signed slot action links — generate with: openssl rand -hex 20
SLOT_SECRET=change_me_to_a_long_random_hex_string
# Password for the /manage slot manager page
MANAGE_PASSWORD=choose_a_strong_password
