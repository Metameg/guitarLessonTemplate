# Block direct browser access to sensitive files
<FilesMatch "^(\.env|composer\.json|composer\.lock)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to slot data files
<FilesMatch "(slot-states|pending-bookings)\.json$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to vendor directory
# Clean URL for slot manager (/manage → php/manage-slots.php)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^manage/?$ php/manage-slots.php [L,QSA]
</IfModule>
